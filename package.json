{
  "name": "antoapps",
  "version": "2.0.0",
  "description": "Sitio web de AntoApps - Next.js",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prebuild": "tsx scripts/validate-sitemap.ts",
    "build": "next build",
    "postbuild": "tsx scripts/validate-sitemap-artifacts.ts",
    "validate:sitemap": "tsx scripts/validate-sitemap.ts",
    "validate:sitemap:artifacts": "tsx scripts/validate-sitemap-artifacts.ts",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "validate:landing": "node scripts/validate-landing-logic.mjs && tsx scripts/validate-android-lead-context.ts && tsx scripts/validate-bienvenida-copy.ts && tsx scripts/validate-home-copy.ts && tsx scripts/validate-home-sections-faq.ts && tsx scripts/validate-psychoeducation.ts && tsx scripts/validate-home-metadata.ts && tsx scripts/validate-pricing.ts && tsx scripts/validate-assets.ts && tsx scripts/validate-sitemap.ts",
    "assets:home-webp": "node scripts/convert-home-screenshots.mjs",
    "validate": "npm run validate:landing && npm run type-check",
    "deploy": "vercel --prod",
    "deploy:preview": "vercel"
  },
  "dependencies": {
    "googleapis": "^173.0.0",
    "mongodb": "^7.2.0",
    "next": "^14.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.1.2",
    "sharp": "^0.34.5",
    "tsx": "^4.22.4",
    "typescript": "^5.4.0"
  },
  "keywords": [
    "web",
    "development",
    "antoapps",
    "nextjs"
  ],
  "author": "Marcelo Ull Marambio",
  "license": "MIT"
}
