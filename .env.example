# Google Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Environment
NEXT_PUBLIC_ENV=production
NEXT_PUBLIC_SITE_URL=https://antoapps.com

# Tiendas (opcional; App Store tiene valor por defecto en código)
NEXT_PUBLIC_APP_STORE_URL=https://apps.apple.com/cl/app/anto/id6756631911
# NEXT_PUBLIC_GOOGLE_PLAY_URL=

# API Endpoints
# URL del backend en Render (ejemplo: https://anto-backend.onrender.com)
NEXT_PUBLIC_BACKEND_URL=https://tu-backend.onrender.com

# Feature Flags (opcional)
# NEXT_PUBLIC_ENABLE_ANALYTICS=true
# NEXT_PUBLIC_ENABLE_PWA=true

